{
  "name": "woeschplan",
  "version": "0.1.0",
  "private": true,
  "description": "Shared laundry scheduling for Swiss apartment buildings",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm run build --workspace=@woeschplan/shared",
    "dev": "npm run dev --workspace=@woeschplan/api & npm run start --workspace=@woeschplan/mobile",
    "dev:api": "npm run dev --workspace=@woeschplan/api",
    "dev:mobile": "npm run start --workspace=@woeschplan/mobile",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:migrate": "npm run db:migrate --workspace=@woeschplan/api",
    "db:seed": "npm run db:seed --workspace=@woeschplan/api",
    "db:studio": "npm run db:studio --workspace=@woeschplan/api"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
